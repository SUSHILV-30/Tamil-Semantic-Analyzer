<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<launchConfiguration type="com.github.jknack.Antlr4.tool">
    <stringAttribute key="antlr4.arguments" value="-no-listener -visitor -encoding UTF-8"/>
    <stringAttribute key="antlr4.grammar" value="/PractiseVisitor/src/LabeledExpr.g4"/>
    <stringAttribute key="antlr4.vmArguments" value=""/>
    <booleanAttribute key="org.eclipse.debug.core.ATTR_FORCE_SYSTEM_CONSOLE_ENCODING" value="false"/>
</launchConfiguration>
