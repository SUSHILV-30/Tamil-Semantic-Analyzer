grammar Expr;

expr
    : expr op=('+'|'-') term     # AddSubExpr
    | term                       # ToTerm
    ;

term
    : term '*' factor            # MulExpr
    | factor                     # ToFactor
    ;

factor
    : '-' factor                 # UnaryMinusExpr
    | '(' expr ')'               # ParenExpr
    | NUMBER  
    | ID                   # NumberExpr
    ;

ID : [a-zA-Z]+;
NUMBER : [0-9]+ ('.' [0-9]+)? ;
WS     : [ \t\r\n]+ -> skip ;