import java.util.Stack;

public class EvalListener extends BoolExprBaseListener{
	
	private Stack<Boolean> stack = new Stack<>();
	
	public boolean getResult() {
		return stack.peek();
	}
	
	@Override
	
	public void exitTrueExpr(BoolExprParser.TrueExprContext ctx) {
		stack.push(true);
		//System.out.println("Pushed True");
	}
	
	@Override
	
	public void exitFalseExpr(BoolExprParser.FalseExprContext ctx) {
		stack.push(false);
		System.out.println("Pushed False");
	}
	
	@Override
	
	public void exitNotExpr(BoolExprParser.NotExprContext ctx) {
		boolean value = stack.pop();
		boolean result = !value;
		stack.push(result);
		System.out.println("Not of : "+value+" = " + result);
	}
	
	@Override
	
	public void exitAndExpr(BoolExprParser.AndExprContext ctx) {
		boolean left = stack.pop();
		boolean right = stack.pop();
		boolean result = left && right;
		stack.push(result);
		System.out.println(left + " AND " + right + " = " + result);
	}
	
@Override
	
	public void exitOrExpr(BoolExprParser.OrExprContext ctx) {
		boolean left = stack.pop();
		boolean right = stack.pop();
		boolean result = left || right;
		stack.push(result);
		System.out.println(left + " AND " + right + " = " + result);
	}
	
}