grammar Expr;

/* ---------------- START RULE ---------------- */

start
    : e=expr EOF
      {
        System.out.println("Result = " + $e.val);
      }
    ;

/* ---------------- EXPR (OR level) ---------------- */

expr returns [boolean val]
    : e1=expr OR t=term
      {
        $val = $e1.val || $t.val;
      }
    | t=term
      {
        $val = $t.val;
      }
    ;

/* ---------------- TERM (AND level) ---------------- */

term returns [boolean val]
    : t1=term AND f=factor
      {
        $val = $t1.val && $f.val;
      }
    | f=factor
      {
        $val = $f.val;
      }
    ;

/* ---------------- FACTOR (Highest precedence) ---------------- */

factor returns [boolean val]
    : NOT f=factor
      {
        $val = !$f.val;
      }
    | '(' e=expr ')'
      {
        $val = $e.val;
      }
    | TRUE
      {
        $val = true;
      }
    | FALSE
      {
        $val = false;
      }
    ;

/* ---------------- LEXER RULES ---------------- */

TRUE  : 'true';
FALSE : 'false';
AND   : 'AND';
OR    : 'OR';
NOT   : 'NOT';

WS : [ \r\n\t]+ -> skip;

